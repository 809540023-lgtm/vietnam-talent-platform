# VietTalent Taiwan - Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/viettalent

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
WEBHOOK_URL=https://your-app.onrender.com/webhook/telegram

# Facebook API
FB_PAGE_ID=your-facebook-page-id
FB_ACCESS_TOKEN=your-facebook-access-token

# Application
SECRET_KEY=your-secret-key-here
DEBUG=false
PORT=8000
